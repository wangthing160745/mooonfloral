  <style>
    /* ── SIZE BADGE ── */
    .size-badge {
      display: inline-flex; align-items: center; justify-content: center;
      width: 32px; height: 32px; border-radius: 50%;
      font-size: 0.7rem; font-weight: 700;
      position: absolute; top: 10px; left: 10px; z-index: 2;
    }
    .size-xs { background: #D4E8C2; color: #3A6B1A; }
    .size-s  { background: #FAD9D9; color: #8B2020; }
    .size-m  { background: #D9EAF7; color: #1A4B7A; }

    /* ── MENU PRODUCT CARD ── */
    .menu-card {
      background: #fff; border-radius: 16px; overflow: hidden;
      box-shadow: var(--shadow); transition: transform 0.25s, box-shadow 0.25s;
      position: relative;
    }
    .menu-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-hover); }

    .menu-thumb {
      width: 100%; aspect-ratio: 1 / 1;
      overflow: hidden; position: relative;
      background: var(--blush);
    }
    .menu-thumb img {
      position: absolute;
      width: 400%;
      height: auto;
    }

    .menu-card .product-body { padding: 1rem 1.1rem 1.2rem; }
    .menu-card .product-name { font-size: 1rem; margin-bottom: 0.25rem; }
    .menu-card .product-footer { display: flex; align-items: center; justify-content: space-between; margin-top: 0.75rem; }

    /* ── SIZE FILTER ── */
    .size-legend {
      display: flex; gap: 1rem; justify-content: center;
      flex-wrap: wrap; margin-bottom: 0.5rem;
    }
    .size-info {
      display: flex; align-items: center; gap: 0.4rem;
      font-size: 0.82rem; color: var(--gray);
    }
    .size-dot {
      width: 10px; height: 10px; border-radius: 50%;
    }

    /* ── CATALOG SECTION ── */
    .catalog-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;
      max-width: 1000px; margin: 0 auto;
    }
    .catalog-img {
      width: 100%; border-radius: 16px;
      box-shadow: var(--shadow); transition: transform 0.2s;
      cursor: zoom-in;
    }
    .catalog-img:hover { transform: scale(1.02); }

    @media (max-width: 640px) {
      .catalog-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
